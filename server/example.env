# Example configuration file
# Actually name it `.env` for it to work

# The backend creates a binded mount to the directory (or file, which I recommend) in the docker compose.
# that is why database_uri is overwritten in the docker compose.
# In production, you need to set this variable to the path of the sqlite database that sits on the machine running the backend docker container.
PATH_TO_DB="/path/to/sqliteDB.db"

# Everything past the 3rd slash is a path to the DB.
# Follow this post for advice with Windows machines: https://stackoverflow.com/questions/56416437/confusion-about-uri-path-to-configure-sqlite-database
# For linux, to store it at `/home/user/dbsGoHere/mySQLiteDB.db` the URI would be: `sqlite:////home/user/dbsGoHere/mySQLiteDB.db`
DATABASE_URI="sqlite:///myDBFile.db"
